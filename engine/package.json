{
  "name": "ai-engine",
  "version": "1.0.0",
  "description": "AI Engine for cockpitAI — polls MongoDB and dispatches tasks to CLI agents",
  "type": "module",
  "main": "aiEngine.js",
  "scripts": {
    "start": "node aiEngine.js",
    "dev": "node --watch aiEngine.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testTimeout=15000"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.21.0",
    "mongoose": "^8.0.3"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "mongodb-memory-server": "^9.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "transform": {}
  }
}
